{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  },
  "AllowedHosts": "*",

  "Cors": {
    "Enabled": true,
    "AllowedOrigins": ["*"],
    "AllowedMethods": ["GET", "POST", "PUT", "DELETE", "OPTIONS"],
    "AllowedHeaders": ["*"]
  },

  "MongoDbSettings": {
    "ConnectionString": "mongodb://10.0.0.5:27017",
    "DatabaseName": "ServiceMeTest",
    "ProvisioningCollection": "provisioning_records",
    "SubscriptionCollection": "subscription_states"
  },

  "Etisalat": {
    "BaseUrl": "https://contentapi-s.etisalat.ae/rest/xaas/v1/",
    "IsvProvisioningStatusEndpoint": "isvProvisioningStatus",
    "Username": "YOUR_ETISALAT_USERNAME",
    "Password": "YOUR_ETISALAT_PASSWORD",
    "TimeoutSeconds": 30,
    "RetryCount": 3,
    "SlaDays": 30
  },

  "Isv": {
    "WhitelistedIps": [
      "127.0.0.1",
      "::1",
      "*"
    ],
    "Username": "isv_user",
    "Password": "isv_password",
    "EnableIpWhitelisting": false
  },

  "TicketMonitor": {
    "Enabled": true,
    "TicketDbConnectionString": "mongodb://10.0.0.5:27017",
    "TicketDbName": "ServiceMeTest",
    "TicketCollectionName": "Ticket",
    "PollingIntervalSeconds": 30,
    "SubjectFilter": "Subscription"
  },

  "UiAuth": {
    "Username": "admin",
    "Password": "@Adm1n@2026#",
    "SessionTimeoutMinutes": 60
  },

  "Sla": {
    "Enabled": true,
    "DefaultSlaDays": 30,
    "WarningThresholdDays": 25,
    "Rules": [
      {
        "Name": "Standard",
        "SlaDays": 30,
        "WarningDays": 25,
        "AppliesTo": "default"
      },
      {
        "Name": "Priority",
        "SlaDays": 7,
        "WarningDays": 5,
        "AppliesTo": "priority"
      },
      {
        "Name": "Critical",
        "SlaDays": 3,
        "WarningDays": 2,
        "AppliesTo": "critical"
      }
    ]
  }
}
