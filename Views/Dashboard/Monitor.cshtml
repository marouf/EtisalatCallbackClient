@model List<TrackedTicket>
@{
    ViewData["Title"] = "Ticket Monitor";
}

<style>
    /* Use the full window width on this page and scroll on small screens */
    .container { max-width: 100%; }
    .table-container { overflow-x: auto; }
    .table-container table { min-width: 1000px; }

    .table-container td { vertical-align: top; }
    th .sort-link {
        color: inherit;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        cursor: pointer;
        white-space: nowrap;
    }
    th .sort-link:hover { color: var(--primary); }
    th .sort-arrow { font-size: 10px; opacity: 0.55; }
    th .sort-link:hover .sort-arrow { opacity: 1; }
</style>

<div class="page-header">
    <div>
        <h1 class="page-title">Ticket Monitor</h1>
        <p class="page-subtitle">Track and manage subscription tickets</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Export" asp-route-format="excel"
           asp-route-status="@ViewBag.StatusFilter" asp-route-callback="@ViewBag.CallbackFilter" asp-route-search="@ViewBag.SearchFilter"
           asp-route-dateRange="@ViewBag.DateRange" asp-route-dateFrom="@ViewBag.DateFrom" asp-route-dateTo="@ViewBag.DateTo"
           class="btn btn-success">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            Export Excel
        </a>
        <a asp-action="Export" asp-route-format="csv"
           asp-route-status="@ViewBag.StatusFilter" asp-route-callback="@ViewBag.CallbackFilter" asp-route-search="@ViewBag.SearchFilter"
           asp-route-dateRange="@ViewBag.DateRange" asp-route-dateFrom="@ViewBag.DateFrom" asp-route-dateTo="@ViewBag.DateTo"
           class="btn btn-secondary">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            Export CSV
        </a>
        <a asp-action="Monitor" class="btn btn-primary">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><path fill-rule="evenodd" d="M8 3a5 5 0 104.546 2.914.5.5 0 01.908-.417A6 6 0 118 2v1z"/><path d="M8 4.466V.534a.25.25 0 01.41-.192l2.36 1.966c.12.1.12.284 0 .384L8.41 4.658A.25.25 0 018 4.466z"/></svg>
            Refresh
        </a>
    </div>
</div>

<form method="get" class="filters">
    <div class="filter-group flex-1">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--text-dim)" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <input type="text" name="search" class="form-control" style="min-width: 220px;" placeholder="Search by ticket # or subject..." value="@ViewBag.SearchFilter" />
    </div>
    <div class="filter-group">
        <span class="filter-label">Status:</span>
        <select name="status" class="form-select">
            <option value="">All</option>
            <option value="Open" selected="@(ViewBag.StatusFilter == "Open")">Open</option>
            <option value="InProgress" selected="@(ViewBag.StatusFilter == "InProgress")">In Progress</option>
            <option value="WaitingForUserInput" selected="@(ViewBag.StatusFilter == "WaitingForUserInput")">Waiting For User</option>
            <option value="Resolved" selected="@(ViewBag.StatusFilter == "Resolved")">Resolved</option>
            <option value="Closed" selected="@(ViewBag.StatusFilter == "Closed")">Closed</option>
            <option value="Reassigned" selected="@(ViewBag.StatusFilter == "Reassigned")">Reassigned</option>
            <option value="Draft" selected="@(ViewBag.StatusFilter == "Draft")">Draft</option>
            <option value="WaitingForVendor" selected="@(ViewBag.StatusFilter == "WaitingForVendor")">Waiting For Vendor</option>
            <option value="WaitingForApproval" selected="@(ViewBag.StatusFilter == "WaitingForApproval")">Waiting For Approval</option>
            <option value="Approved" selected="@(ViewBag.StatusFilter == "Approved")">Approved</option>
            <option value="Rejected" selected="@(ViewBag.StatusFilter == "Rejected")">Rejected</option>
        </select>
    </div>
    <div class="filter-group">
        <span class="filter-label">Callback:</span>
        <select name="callback" class="form-select">
            <option value="">All</option>
            <option value="true" selected="@(ViewBag.CallbackFilter == "true")">Sent (Success)</option>
            <option value="false" selected="@(ViewBag.CallbackFilter == "false")">Pending</option>
            <option value="failed" selected="@(ViewBag.CallbackFilter == "failed")">Failed</option>
        </select>
    </div>
    <div class="filter-group">
        <span class="filter-label">Created:</span>
        <select name="dateRange" class="form-select" id="dateRange" onchange="toggleCustomDates()">
            <option value="">Any time</option>
            <option value="today" selected="@(ViewBag.DateRange == "today")">Today</option>
            <option value="1day" selected="@(ViewBag.DateRange == "1day")">Last 1 day</option>
            <option value="2days" selected="@(ViewBag.DateRange == "2days")">Last 2 days</option>
            <option value="week" selected="@(ViewBag.DateRange == "week")">Last week</option>
            <option value="month" selected="@(ViewBag.DateRange == "month")">Last month</option>
            <option value="custom" selected="@(ViewBag.DateRange == "custom")">Custom…</option>
        </select>
    </div>
    <div class="filter-group" id="customDates" style="display: @(ViewBag.DateRange == "custom" ? "flex" : "none");">
        <input type="date" name="dateFrom" class="form-control" value="@ViewBag.DateFrom" title="From date" />
        <span class="filter-label">to</span>
        <input type="date" name="dateTo" class="form-control" value="@ViewBag.DateTo" title="To date" />
    </div>
    <button type="submit" class="btn btn-secondary">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"/></svg>
        Filter
    </button>
    <span class="text-muted" style="font-size: 13px;">@ViewBag.TotalCount tickets found</span>
</form>

<form id="bulkForm" asp-action="BulkCallback" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" name="action" id="bulkAction" value="" />

    <div class="bulk-actions" id="bulkActions">
        <span class="bulk-count" id="selectedCount">0 selected</span>
        <span class="text-muted">Send callback:</span>
        <button type="button" class="btn btn-success btn-sm" onclick="submitBulk('ACCEPTED')">ACCEPTED</button>
        <button type="button" class="btn btn-warning btn-sm" onclick="submitBulk('REJECTED')">REJECTED</button>
        <button type="button" class="btn btn-danger btn-sm" onclick="submitBulk('EXPIRED')">EXPIRED</button>
        <button type="button" class="btn btn-ghost btn-sm" onclick="clearSelection()">Clear</button>
    </div>

    @{
        string currentSort = ViewBag.Sort as string ?? "";
        string currentDir = ViewBag.Dir as string ?? "";
        Func<string, string> sortUrl = field => Url.Action("Monitor", new
        {
            sort = field,
            dir = (currentSort == field && currentDir == "asc") ? "desc" : "asc",
            status = ViewBag.StatusFilter,
            callback = ViewBag.CallbackFilter,
            search = ViewBag.SearchFilter,
            dateRange = ViewBag.DateRange,
            dateFrom = ViewBag.DateFrom,
            dateTo = ViewBag.DateTo
        })!;
        Func<string, string> sortArrow = field => currentSort == field ? (currentDir == "asc" ? "▲" : "▼") : "⇅";
    }

    <div class="table-container">
        <table style="table-layout: fixed; width: 100%;">
            <thead>
                <tr>
                    <th style="width: 44px;"><input type="checkbox" id="selectAll" onchange="toggleSelectAll()" /></th>
                    <th style="width: 120px;"><a href="@sortUrl("ticket")" class="sort-link">Ticket # <span class="sort-arrow">@sortArrow("ticket")</span></a></th>
                    <th><a href="@sortUrl("subject")" class="sort-link">Subject <span class="sort-arrow">@sortArrow("subject")</span></a></th>
                    <th style="width: 180px;"><a href="@sortUrl("reference")" class="sort-link">Reference No. <span class="sort-arrow">@sortArrow("reference")</span></a></th>
                    <th style="width: 150px;"><a href="@sortUrl("created")" class="sort-link">Created <span class="sort-arrow">@sortArrow("created")</span></a></th>
                    <th style="width: 110px;"><a href="@sortUrl("status")" class="sort-link">Status <span class="sort-arrow">@sortArrow("status")</span></a></th>
                    <th style="width: 105px;"><a href="@sortUrl("callback")" class="sort-link">Callback <span class="sort-arrow">@sortArrow("callback")</span></a></th>
                    <th style="width: 90px;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Count == 0)
                {
                    <tr>
                        <td colspan="8">
                            <div class="empty-state">
                                <div class="icon">
                                    <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
                                </div>
                                <h3>No tickets found</h3>
                                <p>Try adjusting your search or filter criteria</p>
                            </div>
                        </td>
                    </tr>
                }
                @foreach (var ticket in Model)
                {
                    <tr>
                        <td>
                            <input type="checkbox" name="ticketIds" value="@ticket.Id"
                                   class="ticket-checkbox" onchange="updateBulkActions()"
                                   @(ticket.CallbackSent ? "disabled" : "") />
                        </td>
                        <td>
                            <a asp-action="TicketDetails" asp-route-id="@ticket.Id" class="link" style="font-weight: 500;">
                                @ticket.TicketNumber
                            </a>
                        </td>
                        <td style="word-break: break-word; vertical-align: top;">
                            @ticket.Subject
                        </td>
                        <td style="white-space: nowrap; vertical-align: top; color: var(--text-muted);">
                            @(ticket.ReferenceNumber ?? "—")
                        </td>
                        <td class="text-muted" style="white-space: nowrap;">
                            @ticket.TicketCreatedDate.ToString("yyyy-MM-dd HH:mm")
                        </td>
                        <td>
                            <span class="status-pill status-@ticket.CurrentStatus.ToString().ToLower()">
                                @ticket.CurrentStatus
                            </span>
                        </td>
                        @{
                            var isSuccess = ticket.CallbackSent && ticket.CallbackResponseCode == "0";
                            var isFailed = ticket.CallbackSent && ticket.CallbackResponseCode != "0";
                        }
                        <td>
                            @if (isSuccess)
                            {
                                <span class="callback-badge callback-sent">
                                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
                                    @ticket.CallbackAction
                                </span>
                            }
                            else if (isFailed)
                            {
                                <span class="callback-badge callback-failed" style="background: rgba(239,68,68,0.15); color: #f87171;">
                                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
                                    Failed
                                </span>
                            }
                            else
                            {
                                <span class="callback-badge callback-pending">
                                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                                    Pending
                                </span>
                            }
                        </td>
                        <td>
                            @if (!ticket.CallbackSent || isFailed)
                            {
                                <button type="button" class="btn btn-primary btn-sm" onclick="openCallbackModal('@ticket.Id', '@ticket.TicketNumber')">
                                    @(isFailed ? "Retry" : "Send")
                                </button>
                            }
                            else
                            {
                                <span class="text-muted" style="font-size: 12px;">@ticket.CallbackResponseCode</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        @if (ViewBag.TotalPages > 1)
        {
            <div class="pagination">
                <a class="page-link @(ViewBag.CurrentPage <= 1 ? "disabled" : "")"
                   asp-action="Monitor" asp-route-page="@(ViewBag.CurrentPage - 1)"
                   asp-route-status="@ViewBag.StatusFilter" asp-route-callback="@ViewBag.CallbackFilter" asp-route-search="@ViewBag.SearchFilter"
                   asp-route-dateRange="@ViewBag.DateRange" asp-route-dateFrom="@ViewBag.DateFrom" asp-route-dateTo="@ViewBag.DateTo"
                   asp-route-sort="@ViewBag.Sort" asp-route-dir="@ViewBag.Dir">
                    &larr; Previous
                </a>
                @for (int i = 1; i <= ViewBag.TotalPages; i++)
                {
                    <a class="page-link @(i == ViewBag.CurrentPage ? "active" : "")"
                       asp-action="Monitor" asp-route-page="@i"
                       asp-route-status="@ViewBag.StatusFilter" asp-route-callback="@ViewBag.CallbackFilter" asp-route-search="@ViewBag.SearchFilter"
                       asp-route-dateRange="@ViewBag.DateRange" asp-route-dateFrom="@ViewBag.DateFrom" asp-route-dateTo="@ViewBag.DateTo"
                       asp-route-sort="@ViewBag.Sort" asp-route-dir="@ViewBag.Dir">
                        @i
                    </a>
                }
                <a class="page-link @(ViewBag.CurrentPage >= ViewBag.TotalPages ? "disabled" : "")"
                   asp-action="Monitor" asp-route-page="@(ViewBag.CurrentPage + 1)"
                   asp-route-status="@ViewBag.StatusFilter" asp-route-callback="@ViewBag.CallbackFilter" asp-route-search="@ViewBag.SearchFilter"
                   asp-route-dateRange="@ViewBag.DateRange" asp-route-dateFrom="@ViewBag.DateFrom" asp-route-dateTo="@ViewBag.DateTo"
                   asp-route-sort="@ViewBag.Sort" asp-route-dir="@ViewBag.Dir">
                    Next &rarr;
                </a>
            </div>
        }
    </div>
</form>

<div id="callbackModal" class="modal">
    <div class="modal-content">
        <div class="modal-header">
            <h3>Send Callback</h3>
            <button type="button" class="modal-close" onclick="closeModal()">&times;</button>
        </div>
        <form asp-action="SendCallback" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="ticketId" id="modalTicketId" />
            <p class="mb-3">Sending callback for ticket: <strong id="modalTicketNumber" class="text-primary"></strong></p>
            <div class="form-group">
                <label>Reason (optional)</label>
                <input type="text" name="reason" class="form-control" placeholder="Enter reason for this action" style="width: 100%;" />
            </div>
            <p class="text-muted mb-3" style="font-size: 13px;">Select the action to send to Etisalat:</p>
            <div class="d-flex gap-2 flex-wrap">
                <button type="submit" name="action" value="ACCEPTED" class="btn btn-success">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
                    ACCEPTED
                </button>
                <button type="submit" name="action" value="REJECTED" class="btn btn-warning">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                    REJECTED
                </button>
                <button type="submit" name="action" value="EXPIRED" class="btn btn-danger">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                    EXPIRED
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        function toggleCustomDates() {
            const range = document.getElementById('dateRange').value;
            document.getElementById('customDates').style.display = range === 'custom' ? 'flex' : 'none';
        }

        function openCallbackModal(ticketId, ticketNumber) {
            document.getElementById('modalTicketId').value = ticketId;
            document.getElementById('modalTicketNumber').textContent = ticketNumber;
            document.getElementById('callbackModal').classList.add('show');
        }

        function closeModal() {
            document.getElementById('callbackModal').classList.remove('show');
        }

        function toggleSelectAll() {
            const checked = document.getElementById('selectAll').checked;
            document.querySelectorAll('.ticket-checkbox:not(:disabled)').forEach(cb => cb.checked = checked);
            updateBulkActions();
        }

        function updateBulkActions() {
            const checked = document.querySelectorAll('.ticket-checkbox:checked').length;
            const bulkActions = document.getElementById('bulkActions');
            if (checked > 0) {
                bulkActions.classList.add('active');
                document.getElementById('selectedCount').textContent = checked + ' selected';
            } else {
                bulkActions.classList.remove('active');
            }
        }

        function clearSelection() {
            document.querySelectorAll('.ticket-checkbox').forEach(cb => cb.checked = false);
            document.getElementById('selectAll').checked = false;
            updateBulkActions();
        }

        function submitBulk(action) {
            if (confirm('Send ' + action + ' callback to selected tickets?')) {
                document.getElementById('bulkAction').value = action;
                document.getElementById('bulkForm').submit();
            }
        }

        document.getElementById('callbackModal').addEventListener('click', function(e) {
            if (e.target === this) closeModal();
        });

        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape') closeModal();
        });
    </script>
}
